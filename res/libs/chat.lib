@tel 0
@create Chat Manager (CHM)
drop CHM
@set CHM=static
@set CHM=fixed
@set CHM=handler
@attr CHM.channels=|general
@attr CHM.channelAliases=|gen

@attr CHM.>getChannelsForPlayer(id)=filter {v channels} {?contains `members_[%i]` id}

@attr CHM.$chat/list=emit {concat "Chat channels: " {CHM.getChannelsForPlayer %a}} 
